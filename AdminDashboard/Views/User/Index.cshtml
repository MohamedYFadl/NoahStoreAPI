@model IEnumerable<UserViewModel>
@{
    ViewData["Title"] = "Users List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Users Management</h2>
    <a asp-controller="User" asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add New User
    </a>
</div>
 @if(Model.Count() > 0) { 
<!-- Users Table -->
<div class="card">
    <div class="card-body">
        <div class="table-responsive">

                <table class="table table-hover" id="usersTable">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(u=>u.Id)</th>
                        <th>@Html.DisplayNameFor(u=>u.Name)</th>
                        <th>@Html.DisplayNameFor(u => u.UserName)</th>
                        <th>@Html.DisplayNameFor(u => u.Email)</th>
                        <th>@Html.DisplayNameFor(u => u.PhoneNumber)</th>
                        <th>@Html.DisplayNameFor(u => u.Role)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                 <tbody>
                        @foreach(var user in Model)
                        {
                            <tr>
                                <td>@user.Id</td>

                                <td>
                                    <div class="d-flex align-items-center">
                                       @user.Name
                                    </div>
                                </td>
                                <td>@user.UserName</td>
                                <td>@user.Email</td>
                                <td>@user.PhoneNumber</td>
                                <td><span class="badge bg-success">@user.Role</span></td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-Id="@user.Id" asp-controller="User" class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-Id="@user.Id" asp-controller="User" class="btn btn-sm btn-outline-danger" title="Delete" >
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>

                        }

                </tbody>
            </table>
        </div>
    </div>
</div>
 } 



